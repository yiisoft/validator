#. type: Title ##
#: guide/en/built-in-rules-compare.md
#, no-wrap
msgid "Comparison types"
msgstr ""

#. type: Plain text
#: guide/en/built-in-rules-compare.md
msgid "The `type` parameter controls how values are compared:"
msgstr ""

#. type: Bullet: '- '
#: guide/en/built-in-rules-compare.md
msgid "`CompareType::NUMBER` — values are compared as numbers (default)."
msgstr ""

#. type: Bullet: '- '
#: guide/en/built-in-rules-compare.md
msgid "`CompareType::STRING` — values are compared as strings, byte by byte."
msgstr ""

#. type: Bullet: '- '
#: guide/en/built-in-rules-compare.md
msgid "`CompareType::ORIGINAL` — values are compared as-is, without type casting. Required for `DateTime` objects."
msgstr ""

