#. type: Title #
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Configuring rules via PHP attributes"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"The [Attributes] feature introduced in PHP 8 allows an alternative way of "
"configuring rules. If entities/models with their relations are represented "
"as [DTO] classes, attributes make it possible to use such classes to provide "
"rules.  The rules are defined above the properties themselves, which some "
"developers may find more convenient in terms of readability."
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Configuring for a single entity / model"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Given a single `User` entity / model:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"[\n"
"    'name' => [\n"
"        new Required(),\n"
"        new Length(min: 1, max: 50),\n"
"    ],\n"
"    'age' => [\n"
"        new Integer(min: 18, max: 100),\n"
"    ],\n"
"]\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "the PHP attributes equivalent will be:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use JetBrains\\PhpStorm\\Deprecated;\n"
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"final class User\n"
"{\n"
"    public function __construct(\n"
"        // Multiple attributes.\n"
"        #[Required]\n"
"        #[Length(min: 1, max: 50)]\n"
"        // Can be combined with other attributes not related with rules.\n"
"        #[Deprecated]\n"
"        private readonly string $name,\n"
"        // Single attribute.\n"
"        #[Integer(min: 18, max: 100)]\n"
"        private readonly int $age,\n"
"    ) {\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"This example uses the [constructor property promotion] feature introduced in "
"PHP 8. Attributes can also be used with regular properties:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"final class User\n"
"{\n"
"    // Multiple attributes.\n"
"    #[Required]\n"
"    #[Length(min: 1, max: 50)]\n"
"    public readonly string $name;\n"
"\n"
"    // Single attribute.\n"
"    #[Integer(min: 18, max: 100)]\n"
"    public readonly int $age;\n"
"}\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Error messages may include `{property}` placeholder that is replaced with "
"the name of the property. To capitalize the first letter, you can use the "
"`{Property}` placeholder. If you would like the name to be replaced with a "
"custom value, you can specify it using the `Label` attribute:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Label;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"final class User\n"
"{\n"
"    #[Required]\n"
"    #[Length(min: 1, max: 50)]\n"
"    #[Label('First Name')]\n"
"    public readonly string $name;\n"
"}\n"
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Configuring for multiple entities / models with relations"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "An example of rule set for a blog post configured via arrays only:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Each;\n"
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Nested;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"use Yiisoft\\Validator\\Rule\\Url;\n"
"\n"
"[\n"
"    new Nested([\n"
"        'title' => [\n"
"            new Length(min:1, max: 255),\n"
"        ],\n"
"        // One-to-one relation.\n"
"        'author' => new Nested([\n"
"            'name' => [\n"
"                new Required(),\n"
"                new Length(min: 1, max: 50),\n"
"            ],\n"
"            'age' => [\n"
"                new Integer(min: 18, max: 100),\n"
"            ],\n"
"        ]),\n"
"        // One-to-many relation.\n"
"        'files' => new Each([\n"
"            new Nested([\n"
"                'url' => [new Url()],\n"
"            ]),\n"
"        ]),\n"
"    ]),\n"
"];\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "It can be applied to such DTO classes to achieve the same effect:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Each;\n"
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Nested;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"use Yiisoft\\Validator\\Rule\\Url;\n"
"\n"
"final class Post\n"
"{\n"
"    #[Length(min: 1, max: 255)]\n"
"    public string $title;\n"
"\n"
"    // \"Nested\" can be used without arguments, but make sure to fill the value with the instance in this case (here it's\n"
"    // filled right in the constructor).\n"
"    #[Nested]\n"
"    public Author|null $author = null;\n"
"\n"
"    #[Each(new Nested(File::class))]\n"
"    public array $files = [];\n"
"\n"
"    public function __construct()\n"
"    {\n"
"        $this->author = new Author();\n"
"    }\n"
"}\n"
"\n"
"final class Author\n"
"{\n"
"    #[Required]\n"
"    #[Length(min: 1, max: 50)]\n"
"    public string $name;\n"
"\n"
"    #[Integer(min: 18, max: 100)]\n"
"    public int $age;\n"
"}\n"
"\n"
"// Some rules, like \"Nested\" can be also configured through the class attribute.\n"
"\n"
"#[Nested(['url' => new Url()])]\n"
"final class File\n"
"{\n"
"    public string $url;\n"
"}\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"For a better understanding of relations concept, it's recommended to read "
"the [Nested] and [Each] guides."
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Traits"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Attributes can also be used in traits. It might come in handy for reusing "
"the same set of properties with identical rules:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Length;\n"
"\n"
"trait TitleTrait\n"
"{\n"
"    #[Length(max: 255)]\n"
"    public string $title;\n"
"}\n"
"\n"
"final class BlogPost\n"
"{\n"
"    use TitleTrait;\n"
"}\n"
"\n"
"final class WikiArticle\n"
"{\n"
"    use TitleTrait;\n"
"}\n"
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Inheritance"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Inheritance is supported, but there are some things to keep in mind:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\BooleanValue;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Number;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"class Car\n"
"{\n"
"    #[Required]\n"
"    #[Length(min: 1, max: 50)]\n"
"    public string $name;\n"
"    \n"
"    #[Required]\n"
"    #[BooleanValue]\n"
"    public $used;\n"
"    \n"
"    #[Required]\n"
"    #[Number(max: 2000)]\n"
"    public float $weight;     \n"
"}\n"
"\n"
"class Truck extends Car\n"
"{       \n"
"    public string $name;\n"
"    \n"
"    #[Number(max: 3500)]\n"
"    public float $weight;      \n"
"}\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "In this case the set of rules for `Truck` class will be:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\BooleanValue;\n"
"use Yiisoft\\Validator\\Rule\\Number;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"[\n"
"    'used' => [\n"
"        new Required(),\n"
"        new BooleanValue(),\n"
"    ],\n"
"    'weight' => [\n"
"        new Number(max: 3500),\n"
"    ],\n"
"];\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "So, to sum up:"
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Parent rules for overridden properties are ignored completely, only the ones "
"from the child class are obtained."
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"All parent rules for properties that are not overridden in the child class "
"are obtained fully."
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "As for the data, default values set in the child class take precedence."
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Adding attributes support to custom rules"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"In order to attach rules to DTO properties or the whole DTO, the `Attribute` "
"attribute must be added to the custom class. And in order for rules to be "
"fetched from attributes, they must implement the `RuleInterface`."
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "For custom `Composite` rules you only need to add the attribute:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Attribute;\n"
"use Yiisoft\\Validator\\Rule\\Composite;\n"
"use Yiisoft\\Validator\\Rule\\Count;\n"
"use Yiisoft\\Validator\\Rule\\Each;\n"
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"\n"
"// Make sure to add this because attribute inheritance is not supported.\n"
"#[Attribute(Attribute::TARGET_PROPERTY | Attribute::IS_REPEATABLE)]\n"
"final class RgbColorRuleSet extends Composite\n"
"{\n"
"    public function getRules(): array\n"
"    {\n"
"        return [\n"
"            new Count(3),\n"
"            new Each([new Integer(min: 0, max: 255)])\n"
"        ];\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Example for custom rule:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Attribute;\n"
"use Yiisoft\\Validator\\RuleInterface;\n"
"\n"
"#[Attribute(Attribute::TARGET_PROPERTY | Attribute::IS_REPEATABLE)]\n"
"final class Yaml implements RuleInterface\n"
"{\n"
"    public function __construct(\n"
"        public string $incorrectInputMessage = 'Value must be a string. {type} given.',\n"
"        public string $message = 'The value is not a valid YAML.',\n"
"    ) {\n"
"    }\n"
"\n"
"    public function getHandler(): string\n"
"    {\n"
"        return YamlHandler::class;\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"To allow attaching to the class, modify the attribute definition like this:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Attribute;\n"
"use Yiisoft\\Validator\\RuleInterface;\n"
"\n"
"#[Attribute(Attribute::TARGET_CLASS | Attribute::TARGET_PROPERTY | Attribute::IS_REPEATABLE)]\n"
"final class Yaml implements RuleInterface \n"
"{\n"
"    // ...\n"
"}\n"
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Limitations and workarounds"
msgstr ""

#. type: Title ###
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Alternative approaches for complex rules"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"For complex rules involving relations (`Nested`, `Each`), you can use rule "
"providers as an alternative to attributes:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Nested;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"use Yiisoft\\Validator\\Rule\\Url;\n"
"use Yiisoft\\Validator\\RulesProviderInterface;\n"
"use Yiisoft\\Validator\\Validator;\n"
"\n"
"final class Post\n"
"{\n"
"    public function __construct(\n"
"        private string $title,\n"
"        private Author|null $author = null,\n"
"        private array $files = [],\n"
"    ) {\n"
"    }\n"
"}\n"
"\n"
"final class Author\n"
"{\n"
"    public function __construct(\n"
"        private string $name,\n"
"        private int $age,\n"
"    ) {\n"
"    }\n"
"}\n"
"\n"
"final class File\n"
"{\n"
"    private string $url;\n"
"}\n"
"\n"
"final class PostRulesProvider implements RulesProviderInterface\n"
"{\n"
"    public function getRules(): array\n"
"    {\n"
"        return [\n"
"            new Nested([\n"
"                'title' => new Length(min:1, max: 255),\n"
"                'author' => [\n"
"                    'name' => [\n"
"                        new Required(),\n"
"                        new Length(min: 1, max: 50),\n"
"                    ],\n"
"                    'age' => new Integer(min: 18, max: 100),\n"
"                ],\n"
"                'files.*.url' => new Url(),\n"
"            ]),\n"
"        ];\n"
"    }\n"
"}\n"
"\n"
"$post = new Post(title: 'Hello, world!');\n"
"$postRulesProvider = new PostRulesProvider();\n"
"$validator = (new Validator())->validate($post, $postRulesProvider);\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"For rules without relations, instead of using `Composite` directly, create a "
"child class that extends from it and put the rules into it. Don't forget to "
"add the attribute support."
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Attribute;\n"
"use Yiisoft\\Validator\\Rule\\Composite;\n"
"use Yiisoft\\Validator\\Rule\\Count;\n"
"use Yiisoft\\Validator\\Rule\\Each;\n"
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"\n"
"#[Attribute(Attribute::TARGET_PROPERTY | Attribute::IS_REPEATABLE)]\n"
"final class RgbColorRuleSet extends Composite\n"
"{\n"
"    public function getRules(): array\n"
"    {\n"
"        return [\n"
"            new Count(3),\n"
"            new Each([new Integer(min: 0, max: 255)])\n"
"        ];\n"
"    }\n"
"}\n"
"\n"
"final class User\n"
"{\n"
"    public function __construct(\n"
"        private string $name,\n"
"        #[RgbColorRuleSet]\n"
"        private array $avatarBackgroundColor,\n"
"    ) {\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"The `Nested` rule can be used without arguments, see this [example]"
"(#configuring-for-a-single-entity--model) above."
msgstr ""

#. type: Title ###
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Callables"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Attempting to use callables within the scope of an attribute will cause the "
"error. This means that using [when] for [conditional validation] or "
"`callback` argument for the `Callback` rule will not work."
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "The workarounds are:"
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"`Composite` or the rules provider described in the [Instances] section will "
"also fit here."
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Create a [custom rule]."
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"For the `Callback` rule in particular, it is possible to replace a callback "
"with a [method reference]."
msgstr ""

#. type: Title ###
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Function / method calls"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Both function and method calls are not supported within the scope of an "
"attribute. If the intent is to call a function / method for validation - use "
"a `Callback` rule with [method reference]. Otherwise, the remaining options "
"are:"
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Use `Composite` or rules provider described in the [Instances] section."
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Combining attributes with `RulesProviderInterface`"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"When a data object has rules declared via PHP attributes and also implements "
"`RulesProviderInterface`, rules from both sources are merged. Rules from PHP "
"attributes are applied first, followed by rules from `getRules()`. If the "
"same property has rules in both sources, they are combined."
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"> **Note:** This merging only applies when the object is passed as the data (first argument of `validate()`). When\n"
"> passed as the rules argument (second argument), only `getRules()` is used — see [Using validator] for details.\n"
msgstr ""

#. type: Title ##
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Using rules"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Well, the rules are configured. What's next? We can either:"
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Pass them for validation right away."
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Tune the parsing of rules (skippable properties, using cache)."
msgstr ""

#. type: Bullet: '- '
#: guide/en/configuring-rules-via-php-attributes.md
msgid "Use them for something else (e.g. for exporting their options)."
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Let's use a blog post again for demonstration, but a slightly shortened "
"version:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Integer;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Nested;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"final class Post\n"
"{\n"
"    public function __construct(\n"
"        #[Length(min: 1, max: 255)]\n"
"        private string $title,\n"
"\n"
"        #[Nested(Author::class)]\n"
"        private Author|null $author,\n"
"    ) {\n"
"    }\n"
"}\n"
"\n"
"final class Author\n"
"{\n"
"    public function __construct(\n"
"        #[Required]\n"
"        #[Length(min: 1, max: 50)]\n"
"        private string $name,\n"
"\n"
"        #[Integer(min: 18, max: 100)]\n"
"        private int $age,\n"
"    ) {\n"
"    }\n"
"}\n"
msgstr ""

#. type: Title ###
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Passing along with data for validation"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Probably one of the cleanest ways is to pass DTO instances with declared "
"rules and data. This way doesn't require any additional setup:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Validator;\n"
"\n"
"$post = new Post(\n"
"    title: 'Hello, world!',\n"
"    author: new Author(\n"
"        name: 'John',\n"
"        age: 18,\n"
"    ),\n"
");\n"
"$result = (new Validator())->validate($post) // Note `$rules` argument is `null` here.\n"
msgstr ""

#. type: Title ###
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Passing separately for validation"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"It can be helpful to use the class for parsing rules and provide data "
"separately:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Validator;\n"
"\n"
"$data = [\n"
"    'title' => 'Hello, world!',\n"
"    'author' => [\n"
"        'name' => 'John',\n"
"        'age' => 18,\n"
"    ],\n"
"];\n"
"$result = (new Validator())->validate($data, Post::class);\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"The data doesn't have to be within an array, the goal of this snippet is to "
"show that it is isolated from the rules."
msgstr ""

#. type: Title ###
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Tuning parsing of rules"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Data passed for validation as an object will be automatically normalized to "
"`ObjectDataSet`. However, you can manually wrap validated object with this "
"set to allow some additional configuration:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\DataSet\\ObjectDataSet;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Validator;\n"
"\n"
"final class Post\n"
"{\n"
"    // Will be skipped from parsing rules declared via PHP attributes.\n"
"    private $author;\n"
"\n"
"    public function __construct(\n"
"        #[Length(min: 1, max: 255)]\n"
"        public string $title,\n"
"\n"
"        #[Length(min: 1)]\n"
"        protected $content,\n"
"    ) {\n"
"    }\n"
"}\n"
"\n"
"$post = new Post(title: 'Hello, world!', content: 'Test content.');\n"
"$dataSet = new ObjectDataSet(\n"
"    $post,\n"
"    propertyVisibility: ReflectionProperty::IS_PUBLIC | ReflectionProperty::IS_PROTECTED,\n"
"    useCache: false,\n"
");\n"
"$result = (new Validator())->validate($dataSet);\n"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Some edge cases, like skipping DTO's static properties, require using of "
"`AttributesRulesProvider`. After initializing it can be passed for "
"validation right away - no need to extract rules manually beforehand."
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\RulesProvider\\AttributesRulesProvider;\n"
"use Yiisoft\\Validator\\Validator;\n"
"\n"
"final class Post\n"
"{\n"
"    // Will be skipped from parsing rules declared via PHP attributes.\n"
"    private static $cache = [];\n"
"\n"
"    public function __construct(\n"
"        #[Length(min: 1, max: 255)]\n"
"        private string $title,\n"
"    ) {\n"
"    }\n"
"}\n"
"\n"
"$post = new Post(title: 'Hello, world!');\n"
"$rules = new AttributesRulesProvider(Post::class, skipStaticProperties: true);\n"
"$validator = (new Validator())->validate($post, $rules);\n"
msgstr ""

#. type: Title ###
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid "Using rules outside the validator scope"
msgstr ""

#. type: Plain text
#: guide/en/configuring-rules-via-php-attributes.md
msgid ""
"Let's say we want to extract all rules for exporting their options to the "
"client side for further implementing frontend validation:"
msgstr ""

#. type: Fenced code block (php)
#: guide/en/configuring-rules-via-php-attributes.md
#, no-wrap
msgid ""
"use Yiisoft\\Validator\\Helper\\RulesDumper;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\RulesProvider\\AttributesRulesProvider;\n"
"use Yiisoft\\Validator\\Validator;\n"
"\n"
"final class Post\n"
"{\n"
"    public function __construct(\n"
"        #[Length(min: 1, max: 255)]\n"
"        private string $title,\n"
"    ) {\n"
"    }\n"
"}\n"
"\n"
"// The rules need to be extracted manually first.\n"
"$rules = (new AttributesRulesProvider(Post::class))->getRules();\n"
"$validator = (new Validator())->validate([], $rules);\n"
"$options = RulesDumper::asArray($rules);\n"
msgstr ""

